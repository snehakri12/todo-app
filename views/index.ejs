
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TaskFlow</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-zinc-950 text-white overflow-hidden">

    <div class="w-full min-h-screen flex">
        <div class="w-1/2 flex flex-col justify-center px-20">

            <p class="text-blue-400 text-sm tracking-[0.3em] uppercase mb-4">
                Productivity Tracker
            </p>

            <h1 class="text-7xl font-black leading-none">
                Build Better
                <br>
                Days.
            </h1>

            <p class="text-zinc-400 mt-8 text-lg max-w-lg">
                Every Productive Day
Starts With A Plan.
            </p>

            <div class="flex gap-4 mt-10">

                <a href="/login"
                    class="bg-blue-500 px-8 py-4 rounded-xl font-semibold hover:scale-105 duration-200">
                    Login
                </a>

                <a href="/signup"
                    class="border border-zinc-700 px-8 py-4 rounded-xl hover:bg-zinc-900 duration-200">
                    Create Account
                </a>

            </div>

        </div>
        <div class="w-1/2 flex items-center justify-center relative">

            <div class="absolute w-96 h-96 bg-blue-500 rounded-full blur-[150px] opacity-30"></div>

            <div class="relative bg-zinc-900 border border-zinc-800 p-8 rounded-3xl w-[450px]">

                <h3 class="text-xl mb-6">Today's Progress</h3>

                <div class="mb-6">
                    <div class="flex justify-between mb-2">
                        <span>Efficiency</span>
                        <span>80%</span>
                    </div>

                    <div class="h-3 bg-zinc-800 rounded-full overflow-hidden">
                        <div class="h-full w-[80%] bg-green-500"></div>
                    </div>
                </div>

                <div class="space-y-4">

                    <div class="flex items-center gap-3">
                        <input type="checkbox" checked>
                        <p>Complete DSA Practice</p>
                    </div>

                    <div class="flex items-center gap-3">
                        <input type="checkbox" checked>
                        <p>Work on Productivity Tracker</p>
                    </div>

                    <div class="flex items-center gap-3">
                        <input type="checkbox">
                        <p>Read System Design Notes</p>
                    </div>

                    <div class="flex items-center gap-3">
                        <input type="checkbox">
                        <p>Gym Workout</p>
                    </div>

                </div>

                <div class="mt-8 text-green-400">
                    🔥 12 Day Streak
                </div>

            </div>

        </div>

    </div>

</body>
</html>

