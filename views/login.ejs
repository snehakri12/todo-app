
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-950 text-white">

<div class="w-full min-h-screen flex">
    <div class="w-1/2 flex flex-col justify-center px-20">

        <h1 class="text-7xl font-black leading-none">
            Welcome
            <br>
            Back.
        </h1>

        <p class="text-zinc-400 text-lg mt-8 max-w-lg">
            Your goals are waiting. Let's continue where you left off.
        </p>

        <div class="mt-10 bg-zinc-900 border border-zinc-800 rounded-3xl p-8 w-[400px]">

            <h3 class="text-xl mb-5">Today's Progress</h3>

            <div class="bg-zinc-800 h-3 rounded-full overflow-hidden">
                <div class="bg-green-500 h-full w-[80%]"></div>
            </div>

            <p class="mt-4 text-green-400">
                🔥 12 Day Streak
            </p>

            <p class="text-zinc-400 mt-2">
                8 / 10 Tasks Completed
            </p>

        </div>

    </div>

    <!-- Right -->
    <div class="w-1/2 flex items-center justify-center">

        <div class="bg-zinc-900 border border-zinc-800 p-10 rounded-3xl w-[500px]">

            <h2 class="text-3xl font-bold mb-8">
                Login
            </h2>

            <form action="/login" method="post" class="space-y-4">

                <input class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="email" name="email" placeholder="Email">

                <input class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="password" name="password" placeholder="Password">

                <button class="w-full bg-blue-500 py-3 rounded-xl font-semibold hover:bg-blue-600">
                    Continue My Journey
                </button>

            </form>

            <p class="mt-6 text-zinc-400">
                Don't have an account?
                <a href="/signup" class="text-blue-500">Create Account</a>
            </p>

        </div>

    </div>

</div>

</body>
</html>

