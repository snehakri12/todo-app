<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-zinc-950 text-white">

<div class="w-full min-h-screen flex flex-col lg:flex-row">
    <div class="w-full lg:w-1/2 flex flex-col justify-center px-6 sm:px-10 md:px-16 lg:px-20 py-12 text-center lg:text-left">

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black leading-tight">
            Welcome
            <br>
            Back.
        </h1>

        <p class="text-zinc-400 text-base sm:text-lg mt-6 max-w-lg mx-auto lg:mx-0">
            Your goals are waiting. Let's continue where you left off.
        </p>

        <div class="mt-8 bg-zinc-900 border border-zinc-800 rounded-3xl p-6 sm:p-8 w-full max-w-sm sm:max-w-md mx-auto lg:mx-0">

            <h3 class="text-lg sm:text-xl mb-5 font-semibold">
                Today's Progress
            </h3>

            <div class="bg-zinc-800 h-3 rounded-full overflow-hidden">
                <div class="bg-green-500 h-full w-[80%]"></div>
            </div>

            <p class="mt-4 text-green-400 text-sm sm:text-base">
                🔥 12 Day Streak
            </p>

            <p class="text-zinc-400 mt-2 text-sm sm:text-base">
                8 / 10 Tasks Completed
            </p>

        </div>

    </div>
    <div class="w-full lg:w-1/2 flex items-center justify-center px-4 py-10">

        <div class="bg-zinc-900 border border-zinc-800 p-6 sm:p-8 md:p-10 rounded-3xl w-full max-w-sm sm:max-w-md">

            <h2 class="text-2xl sm:text-3xl font-bold mb-8 text-center">
                Login
            </h2>

            <form action="/login" method="post" class="space-y-4">

                <input
                    class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="email"
                    name="email"
                    placeholder="Email"
                    required>

                <input
                    class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="password"
                    name="password"
                    placeholder="Password"
                    required>

                <button
                    class="w-full bg-blue-500 py-3 rounded-xl font-semibold hover:bg-blue-600 transition">
                    Continue My Journey
                </button>

            </form>

            <p class="mt-6 text-zinc-400 text-center text-sm sm:text-base">
                Don't have an account?
                <a href="/signup" class="text-blue-500 hover:underline">
                    Create Account
                </a>
            </p>

        </div>

    </div>

</div>

</body>
</html>