
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-zinc-950 text-white">

<div class="w-full min-h-screen p-10">

    <div class="flex justify-between items-center mb-10">

        <div class="flex items-center gap-5">

          <img
src="<%= user.profilepic && user.profilepic !== 'default.png'
? user.profilepic
: '/images/default.png' %>"
class="w-24 h-24 rounded-full object-cover border-4 border-blue-500"
alt="Profile">

            <div>
                <h1 class="text-4xl font-bold">
                    Hi, <%= user.name %> 👋
                </h1>

                <p class="text-zinc-400">
                    Organize your day and achieve more.
                </p>

                <a
                    href="/profile/upload"
                    class="inline-block mt-2 text-blue-400 hover:text-blue-300">
                    Change Photo
                </a>
            </div>

        </div>

        <a
            href="/logout"
            class="bg-red-500 px-4 py-2 rounded-xl hover:bg-red-600 transition">
            Logout
        </a>

    </div>

    <div class="bg-gradient-to-r from-zinc-900 via-zinc-800 to-zinc-900 
    border border-zinc-700 p-8 rounded-3xl mb-10 flex justify-between items-center shadow-lg">

        <div>

            <p class="text-blue-400 uppercase tracking-[0.3em] text-sm mb-3">
                Productivity Dashboard
            </p>

            <h2 class="text-5xl font-black leading-none">
                Today’s Focus
            </h2>

            <p class="text-zinc-400 mt-4 text-lg max-w-lg">
                Stay consistent, complete your tasks, and build momentum one step at a time ✨
            </p>


            <div class="flex gap-4 mt-6">


                <div class="bg-zinc-700 px-4 py-2 rounded-xl">
                    <p class="text-xs text-zinc-400">Tasks Done</p>
                    <h4 class="text-xl font-bold text-green-400">
                        <%= user.tasks.filter(task => task.completed).length %>
                    </h4>
                </div>

    
                <div class="bg-zinc-700 px-4 py-2 rounded-xl">
                    <p class="text-xs text-zinc-400">Pending</p>
                    <h4 class="text-xl font-bold text-yellow-400">
                        <%= user.tasks.filter(task => !task.completed).length %>
                    </h4>
                </div>

    
                <div class="bg-orange-500 px-4 py-2 rounded-xl">
                    <p class="text-xs text-white">Current Streak</p>
                    <h4 class="text-xl font-bold">
                        🔥 <%= user.streak %> days
                    </h4>
                </div>

            </div>

        </div>

    
        <div class="text-right">

            <h3 class="text-3xl font-bold text-blue-400">
                <%= new Date().toLocaleDateString('en-US', {
                    weekday: 'long'
                }) %>
            </h3>

            <p class="text-zinc-300 text-xl mt-2">
                <%= new Date().toLocaleDateString('en-US', {
                    day: 'numeric',
                    month: 'long',
                    year: 'numeric'
                }) %>
            </p>

        
            <p id="live-time"
               class="text-green-400 text-5xl font-black mt-5 tracking-tight">
            </p>

        </div>

    </div>

    
    <div class="bg-zinc-900 border border-zinc-800 p-6 rounded-3xl mb-10">

        <h2 class="text-2xl font-semibold mb-5">
            Add New Task
        </h2>

        <form
            action="/task/create"
            method="post"
            class="flex gap-3">

            <input
                type="text"
                name="title"
                required
                placeholder="What do you want to do today?"
                class="flex-1 bg-zinc-800 px-4 py-3 rounded-xl outline-none">

            <button
                class="bg-blue-500 px-6 rounded-xl hover:bg-blue-600 transition">
                Add
            </button>

        </form>

    </div>


    <div class="bg-zinc-900 border border-zinc-800 p-6 rounded-3xl">

        <h2 class="text-2xl font-semibold mb-6">
            Today's Tasks
        </h2>

        <% user.tasks.forEach(function(task){ %>

            <div class="flex items-center gap-4 bg-zinc-800 p-4 rounded-xl mb-3">

                <!-- Checkbox -->
                <a href="/task/complete/<%= task._id %>">

                    <% if(task.completed){ %>

                        <div class="w-6 h-6 rounded-md bg-green-500 flex items-center justify-center text-white font-bold">
                            ✓
                        </div>

                    <% } else { %>

                        <div class="w-6 h-6 rounded-md border-2 border-zinc-500">
                        </div>

                    <% } %>

                </a>

        
                <p class="flex-1 text-lg <%= task.completed ? 'line-through text-zinc-500' : '' %>">
                    <%= task.title %>
                </p>

            </div>

        <% }) %>

    </div>

</div>


<div class="fixed bottom-8 right-8">

    <div class="relative w-36 h-36">

        <svg class="w-full h-full rotate-[-90deg]" viewBox="0 0 120 120">

            <circle
                cx="60"
                cy="60"
                r="50"
                stroke="#3f3f46"
                stroke-width="10"
                fill="none"
            />

            <circle
                cx="60"
                cy="60"
                r="50"
                stroke="#a855f7"
                stroke-width="10"
                fill="none"
                stroke-linecap="round"
                stroke-dasharray="314"
                stroke-dashoffset="<%= 314 - (314 * productivity / 100) %>"
            />

        </svg>

        <div class="absolute inset-0 flex flex-col items-center justify-center">

            <h2 class="text-2xl font-bold text-purple-400">
                <%= productivity %>%
            </h2>

            <p class="text-xs text-zinc-400">
                Productivity
            </p>

        </div>

    </div>

</div>

<script>
function updateTime() {
    const now = new Date();

    const time = now.toLocaleTimeString('en-US', {
        hour: '2-digit',
        minute: '2-digit'
    });

    document.getElementById("live-time").innerText = time;
}

updateTime();
setInterval(updateTime, 1000);
</script>


</body>
</html>
