
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Profile Picture</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-zinc-950 text-white">

<div class="w-full min-h-screen flex items-center justify-center px-5">

    <div class="w-full max-w-xl bg-zinc-900 border border-zinc-800 rounded-3xl p-10 shadow-2xl">

    
        <div class="text-center mb-8">

            <h2 class="text-4xl font-black mb-3">
                Update Your Profile
            </h2>

            <p class="text-zinc-400 text-lg">
                Choose a new photo to personalize your workspace ✨
            </p>

        </div>

    
        <form
            action="/upload"
            method="post"
            enctype="multipart/form-data"
            class="space-y-6">

            
            <div class="bg-zinc-800 rounded-2xl p-5 border border-zinc-700">

                <label class="block mb-3 text-zinc-300 font-semibold">
                    Select Image
                </label>

                <div class="flex items-center gap-4">

        
                    <label
                        for="image"
                        class="bg-blue-500 px-5 py-3 rounded-xl cursor-pointer hover:bg-blue-600 transition font-semibold">
                        Choose File
                    </label>

    
                    <span
                        id="file-name"
                        class="bg-zinc-700 text-zinc-300 px-4 py-3 rounded-xl flex-1">
                        No file chosen
                    </span>

                </div>

                <input
                    id="image"
                    type="file"
                    name="image"
                    class="hidden"
                    onchange="updateFileName(this)">
            </div>

            
            <button
                class="w-full bg-green-500 py-3 rounded-xl font-semibold hover:bg-green-600 transition">
                Upload Photo
            </button>

        </form>

        <div class="mt-6 text-center">
            <a
                href="/profile"
                class="text-zinc-400 hover:text-white transition">
                ← Back to Dashboard
            </a>
        </div>

    </div>

</div>

<script>
function updateFileName(input) {
    const fileName = input.files.length > 0
        ? input.files[0].name
        : "No file chosen";

    document.getElementById("file-name").innerText = fileName;
}
</script>

</body>
</html>

