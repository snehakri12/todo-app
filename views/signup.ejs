<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-zinc-950 text-white">

<div class="w-full min-h-screen flex flex-col lg:flex-row">

    <div class="w-full lg:w-1/2 flex flex-col justify-center px-6 sm:px-10 md:px-16 lg:px-20 py-12 text-center lg:text-left">

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black leading-tight">
            Start Your
            <br>
            Productivity
            <br>
            Journey.
        </h1>

        <p class="text-zinc-400 text-base sm:text-lg mt-6 max-w-lg mx-auto lg:mx-0">
            Create your account and transform daily goals into achievements.
            Track habits, monitor progress, and become better every day.
        </p>

        <div class="mt-8 space-y-3 text-zinc-300 text-sm sm:text-base max-w-sm mx-auto lg:mx-0">

            <p>✓ Daily Task Management</p>
            <p>✓ Productivity Analytics</p>
            <p>✓ Efficiency Tracking</p>
            <p>✓ Streak Monitoring</p>

        </div>

    </div>
    <div class="w-full lg:w-1/2 flex items-center justify-center px-4 py-10">

        <div class="bg-zinc-900 border border-zinc-800 p-6 sm:p-8 md:p-10 rounded-3xl w-full max-w-sm sm:max-w-md">

            <h2 class="text-2xl sm:text-3xl font-bold mb-8 text-center">
                Create Account
            </h2>

            <form action="/register" method="post" class="space-y-4">

                <input
                    class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="text"
                    name="name"
                    placeholder="Full Name"
                    required>

                <input
                    class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="text"
                    name="username"
                    placeholder="Username"
                    required>

                <input
                    class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="email"
                    name="email"
                    placeholder="Email"
                    required>

                <input
                    class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="password"
                    name="password"
                    placeholder="Password"
                    required>

                <input
                    class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="number"
                    name="age"
                    placeholder="Age"
                    required>

                <button
                    class="w-full bg-blue-500 py-3 rounded-xl font-semibold hover:bg-blue-600 transition">
                    Create My Workspace
                </button>

            </form>

            <p class="mt-6 text-zinc-400 text-center text-sm sm:text-base">
                Already have an account?
                <a href="/login" class="text-blue-500 hover:underline">
                    Login
                </a>
            </p>

        </div>

    </div>

</div>

</body>
</html>