
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-950 text-white">

<div class="w-full min-h-screen flex">

    <!-- Left Section -->
    <div class="w-1/2 flex flex-col justify-center px-20">

        <h1 class="text-7xl font-black leading-none">
            Start Your
            <br>
            Productivity
            <br>
            Journey.
        </h1>

        <p class="text-zinc-400 text-lg mt-8 max-w-lg">
            Create your account and transform daily goals into achievements.
            Track habits, monitor progress, and become better every day.
        </p>

        <div class="mt-10 space-y-3 text-zinc-300">
            <p>✓ Daily Task Management</p>
            <p>✓ Productivity Analytics</p>
            <p>✓ Efficiency Tracking</p>
            <p>✓ Streak Monitoring</p>
        </div>

    </div>

    <!-- Right Section -->
    <div class="w-1/2 flex items-center justify-center">

        <div class="bg-zinc-900 border border-zinc-800 p-10 rounded-3xl w-[500px]">

            <h2 class="text-3xl font-bold mb-8">
                Create Account
            </h2>

            <form action="/register" method="post" class="space-y-4">

                <input class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="text" name="name" placeholder="Full Name">

                <input class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="text" name="username" placeholder="Username">

                <input class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="email" name="email" placeholder="Email">

                <input class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="password" name="password" placeholder="Password">

                <input class="w-full px-4 py-3 rounded-xl bg-zinc-800 outline-none"
                    type="number" name="age" placeholder="Age">

                <button class="w-full bg-blue-500 py-3 rounded-xl font-semibold hover:bg-blue-600">
                    Create My Workspace
                </button>

            </form>

            <p class="mt-6 text-zinc-400">
                Already have an account?
                <a href="/login" class="text-blue-500">Login</a>
            </p>

        </div>

    </div>

</div>

</body>
</html>
